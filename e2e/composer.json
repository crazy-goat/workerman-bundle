{
    "name": "workerman-bundle/test-app",
    "description": "Integration test app for WorkermanBundle",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.2",
        "crazy-goat/workerman-bundle": "*",
        "symfony/framework-bundle": "^6.4|^7.0|^8.0",
        "symfony/console": "^6.4|^7.0|^8.0",
        "symfony/runtime": "^6.4|^7.0|^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../..",
            "options": { "symlink": false }
        }
    ],
    "config": {
        "allow-plugins": { "symfony/runtime": true }
    }
}
